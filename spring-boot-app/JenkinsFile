pipeline {
    // Prevent Jenkins from checking out the repository on the host node
    options {
        skipDefaultCheckout true
    }

    // Use a Docker agent with the same UID as the Jenkins user
    agent {
        docker {
            image 'hetratanpara/maven-jenkins-agent:java17'
            args '--user 105:105 -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        // Reusable environment variables
        SONAR_URL = "http://34.207.200.224:9000/"
        DOCKER_REGISTRY = "https://index.docker.io/v1/"
        DOCKER_IMAGE_NAME = "hetratanpara/ultimate-cicd-demo"
        GIT_REPO_NAME = "jenkins-cicd"
        GIT_USER_NAME = "het-ratanpara"
    }

    stages {
        stage('Checkout') {
            steps {
                script {
                    // Clean and clone the repository from scratch
                    sh '''
                        # If .git already exists, remove it to avoid permission leftovers
                        rm -rf .git
                        git init
                        git remote add origin https://github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git
                        git fetch --depth 1 origin main
                        git reset --hard origin/main
                        git clean -fd
                    '''
                }
                // Optional: verify the checkout
                sh 'ls -ltr'
            }
        }

        stage('Build and Test') {
            steps {
                sh 'cd spring-boot-app && mvn clean package'
            }
        }

        stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                    sh '''
                        cd spring-boot-app
                        mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}
                    '''
                }
            }
        }

        stage('Build and Push Docker Image') {
            steps {
                script {
                    def dockerImage = "${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}"
                    sh "cd spring-boot-app && docker build -t ${dockerImage} ."
                    docker.withRegistry(DOCKER_REGISTRY, 'docker-cred') {
                        docker.image(dockerImage).push()
                    }
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                dir("${WORKSPACE}") {
                    withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                        sh '''
                            # Configure Git user identity (local to this repository)
                            git config user.email "hetkumar@cloudthat.com"
                            git config user.name "Het Ratanpara"

                            # Replace the entire image line with the new tag
                            sed -i "s|^[[:space:]]*image:.*|    image: ${DOCKER_IMAGE_NAME}:${BUILD_NUMBER}|" spring-boot-app-manifests/deployment.yml

                            # Stage the change
                            git add spring-boot-app-manifests/deployment.yml

                            # Commit only if there are changes
                            git commit -m "Update deployment image to version ${BUILD_NUMBER}" || echo "No changes to commit"

                            # Push to the main branch using the token for authentication
                            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
                        '''
                    }
                }
            }
        }
    }

    post {
        failure {
            echo "❌ Pipeline failed! Check the logs above."
        }
        success {
            echo "✅ Pipeline succeeded! Deployment image updated to version ${BUILD_NUMBER}."
        }
        cleanup {
            cleanWs()
        }
    }   
}